{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.44.1.10279",
      "templateHash": "12865749004263201266"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Deployment location for the cert-runner stack."
      }
    },
    "prefix": {
      "type": "string",
      "defaultValue": "l7cert",
      "metadata": {
        "description": "Name prefix for cert-runner resources."
      }
    },
    "dnsZoneName": {
      "type": "string",
      "metadata": {
        "description": "DNS zone name for ACME DNS-01 validation."
      }
    },
    "dnsZoneResourceGroup": {
      "type": "string",
      "defaultValue": "[resourceGroup().name]",
      "metadata": {
        "description": "Resource group containing the DNS zone."
      }
    },
    "keyVaultName": {
      "type": "string",
      "metadata": {
        "description": "Key Vault name where certificate is imported."
      }
    },
    "keyVaultResourceGroup": {
      "type": "string",
      "defaultValue": "[resourceGroup().name]",
      "metadata": {
        "description": "Resource group containing the Key Vault."
      }
    },
    "createManagedKeyVault": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "Create a managed Key Vault in this deployment resource group if one does not exist."
      }
    },
    "keyVaultAccessMode": {
      "type": "string",
      "defaultValue": "PublicAccess",
      "metadata": {
        "description": "Key Vault connectivity mode: PublicAccess, ServiceEndpoint, or PrivateEndpoint."
      }
    },
    "keyVaultTenantId": {
      "type": "string",
      "defaultValue": "[subscription().tenantId]",
      "metadata": {
        "description": "Tenant ID for a managed Key Vault when createManagedKeyVault is true."
      }
    },
    "persistManagedKeyVault": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Keep managed Key Vault after cert-runner cleanup."
      }
    },
    "applyManagedKeyVaultLock": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Apply delete lock to managed persistent Key Vault."
      }
    },
    "dndDeleteAfterUtc": {
      "type": "string",
      "defaultValue": "Never",
      "metadata": {
        "description": "deleteAfterUtc tag value for managed persistent Key Vault."
      }
    },
    "keyVaultCertificateName": {
      "type": "string",
      "metadata": {
        "description": "Certificate object name in Key Vault."
      }
    },
    "primaryDomain": {
      "type": "string",
      "metadata": {
        "description": "Primary domain name for certificate issuance."
      }
    },
    "additionalDomains": {
      "type": "array",
      "defaultValue": [],
      "metadata": {
        "description": "Additional SAN entries for certificate issuance."
      }
    },
    "vmSize": {
      "type": "string",
      "defaultValue": "Standard_B2s",
      "metadata": {
        "description": "Linux VM size for the one-shot runner."
      }
    },
    "adminUsername": {
      "type": "string",
      "defaultValue": "azureuser",
      "metadata": {
        "description": "Admin username for the runner VM."
      }
    },
    "adminSshPublicKey": {
      "type": "securestring",
      "metadata": {
        "description": "SSH public key for the runner VM."
      }
    },
    "sshAllowedCidr": {
      "type": "string",
      "defaultValue": "0.0.0.0/0",
      "metadata": {
        "description": "CIDR allowed for SSH. Use a locked-down source in practice."
      }
    },
    "letsEncryptEmail": {
      "type": "string",
      "metadata": {
        "description": "Contact email for Lets Encrypt registration."
      }
    },
    "cloudInit": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Cloud-init content. Defaults to installing certbot and az cli."
      }
    },
    "deleteVmOnSuccess": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Delete the VM after successful import."
      }
    },
    "keyVaultPrivateDnsZoneName": {
      "type": "string",
      "defaultValue": "privatelink.vaultcore.azure.net",
      "metadata": {
        "description": "Private DNS zone name used for Key Vault private endpoint resolution."
      }
    },
    "keyVaultPrivateDnsZoneResourceGroup": {
      "type": "string",
      "defaultValue": "[resourceGroup().name]",
      "metadata": {
        "description": "Resource group containing the private DNS zone for Key Vault."
      }
    },
    "createPrivateDnsZone": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "Create private DNS zone in the current RG when using private endpoint mode."
      }
    }
  },
  "variables": {
    "vmName": "[format('{0}-runner-vm', parameters('prefix'))]",
    "pipName": "[format('{0}-runner-pip', parameters('prefix'))]",
    "nsgName": "[format('{0}-runner-nsg', parameters('prefix'))]",
    "vnetName": "[format('{0}-runner-vnet', parameters('prefix'))]",
    "subnetName": "runner-subnet",
    "nicName": "[format('{0}-runner-nic', parameters('prefix'))]",
    "privateEndpointName": "[format('{0}-kv-pe', parameters('prefix'))]",
    "privateDnsZoneLinkName": "[format('{0}-kvdns-link', parameters('prefix'))]",
    "isPublicAccessMode": "[equals(parameters('keyVaultAccessMode'), 'PublicAccess')]",
    "isServiceEndpointMode": "[equals(parameters('keyVaultAccessMode'), 'ServiceEndpoint')]",
    "isPrivateEndpointMode": "[equals(parameters('keyVaultAccessMode'), 'PrivateEndpoint')]",
    "effectiveKeyVaultId": "[if(parameters('createManagedKeyVault'), resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName')), resourceId(parameters('keyVaultResourceGroup'), 'Microsoft.KeyVault/vaults', parameters('keyVaultName')))]",
    "privateDnsZoneId": "[if(parameters('createPrivateDnsZone'), resourceId('Microsoft.Network/privateDnsZones', parameters('keyVaultPrivateDnsZoneName')), resourceId(parameters('keyVaultPrivateDnsZoneResourceGroup'), 'Microsoft.Network/privateDnsZones', parameters('keyVaultPrivateDnsZoneName')))]",
    "canManagePrivateDnsInCurrentRg": "[equals(parameters('keyVaultPrivateDnsZoneResourceGroup'), resourceGroup().name)]",
    "defaultCloudInit": "#cloud-config\r\npackage_update: true\r\npackages:\r\n  - certbot\r\n  - python3-certbot-dns-azure\r\n  - jq\r\nruncmd:\r\n  - [ bash, -lc, \"curl -sL https://aka.ms/InstallAzureCLIDeb | bash\" ]\r\n  - [ bash, -lc, \"mkdir -p /opt/certmgr\" ]\r\n  - [ bash, -lc, \"echo Ready > /opt/certmgr/bootstrap.complete\" ]\r\n"
  },
  "resources": [
    {
      "type": "Microsoft.Network/networkSecurityGroups",
      "apiVersion": "2024-05-01",
      "name": "[variables('nsgName')]",
      "location": "[parameters('location')]",
      "properties": {
        "securityRules": [
          {
            "name": "allow-ssh",
            "properties": {
              "protocol": "Tcp",
              "sourcePortRange": "*",
              "destinationPortRange": "22",
              "sourceAddressPrefix": "[parameters('sshAllowedCidr')]",
              "destinationAddressPrefix": "*",
              "access": "Allow",
              "priority": 100,
              "direction": "Inbound"
            }
          },
          {
            "name": "allow-http",
            "properties": {
              "protocol": "Tcp",
              "sourcePortRange": "*",
              "destinationPortRange": "80",
              "sourceAddressPrefix": "*",
              "destinationAddressPrefix": "*",
              "access": "Allow",
              "priority": 110,
              "direction": "Inbound"
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Network/virtualNetworks",
      "apiVersion": "2024-05-01",
      "name": "[variables('vnetName')]",
      "location": "[parameters('location')]",
      "properties": {
        "addressSpace": {
          "addressPrefixes": [
            "10.99.0.0/24"
          ]
        },
        "subnets": [
          {
            "name": "[variables('subnetName')]",
            "properties": {
              "addressPrefix": "10.99.0.0/26",
              "networkSecurityGroup": {
                "id": "[resourceId('Microsoft.Network/networkSecurityGroups', variables('nsgName'))]"
              },
              "privateEndpointNetworkPolicies": "[if(variables('isPrivateEndpointMode'), 'Disabled', 'Enabled')]",
              "serviceEndpoints": "[if(variables('isServiceEndpointMode'), createArray(createObject('service', 'Microsoft.KeyVault')), createArray())]"
            }
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/networkSecurityGroups', variables('nsgName'))]"
      ]
    },
    {
      "type": "Microsoft.Network/publicIPAddresses",
      "apiVersion": "2024-05-01",
      "name": "[variables('pipName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Standard"
      },
      "properties": {
        "publicIPAllocationMethod": "Static",
        "publicIPAddressVersion": "IPv4"
      }
    },
    {
      "type": "Microsoft.Network/networkInterfaces",
      "apiVersion": "2024-05-01",
      "name": "[variables('nicName')]",
      "location": "[parameters('location')]",
      "properties": {
        "ipConfigurations": [
          {
            "name": "ipconfig1",
            "properties": {
              "subnet": {
                "id": "[reference(resourceId('Microsoft.Network/virtualNetworks', variables('vnetName')), '2024-05-01').subnets[0].id]"
              },
              "privateIPAllocationMethod": "Dynamic",
              "publicIPAddress": {
                "id": "[resourceId('Microsoft.Network/publicIPAddresses', variables('pipName'))]"
              }
            }
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/publicIPAddresses', variables('pipName'))]",
        "[resourceId('Microsoft.Network/virtualNetworks', variables('vnetName'))]"
      ]
    },
    {
      "type": "Microsoft.Compute/virtualMachines",
      "apiVersion": "2024-03-01",
      "name": "[variables('vmName')]",
      "location": "[parameters('location')]",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "hardwareProfile": {
          "vmSize": "[parameters('vmSize')]"
        },
        "osProfile": {
          "computerName": "[variables('vmName')]",
          "adminUsername": "[parameters('adminUsername')]",
          "linuxConfiguration": {
            "disablePasswordAuthentication": true,
            "ssh": {
              "publicKeys": [
                {
                  "path": "[format('/home/{0}/.ssh/authorized_keys', parameters('adminUsername'))]",
                  "keyData": "[parameters('adminSshPublicKey')]"
                }
              ]
            }
          },
          "customData": "[base64(if(empty(parameters('cloudInit')), variables('defaultCloudInit'), parameters('cloudInit')))]"
        },
        "storageProfile": {
          "imageReference": {
            "publisher": "Canonical",
            "offer": "0001-com-ubuntu-server-jammy",
            "sku": "22_04-lts-gen2",
            "version": "latest"
          },
          "osDisk": {
            "createOption": "FromImage",
            "managedDisk": {
              "storageAccountType": "Standard_LRS"
            }
          }
        },
        "networkProfile": {
          "networkInterfaces": [
            {
              "id": "[resourceId('Microsoft.Network/networkInterfaces', variables('nicName'))]",
              "properties": {
                "primary": true
              }
            }
          ]
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/networkInterfaces', variables('nicName'))]"
      ]
    },
    {
      "condition": "[parameters('createManagedKeyVault')]",
      "type": "Microsoft.KeyVault/vaults",
      "apiVersion": "2023-07-01",
      "name": "[parameters('keyVaultName')]",
      "location": "[parameters('location')]",
      "tags": {
        "cleanupPolicy": "DND",
        "deleteAfterUtc": "[parameters('dndDeleteAfterUtc')]",
        "certRunnerPersistent": "[string(parameters('persistManagedKeyVault'))]",
        "deployedBy": "cert-runner-template"
      },
      "properties": {
        "tenantId": "[parameters('keyVaultTenantId')]",
        "sku": {
          "family": "A",
          "name": "standard"
        },
        "enableRbacAuthorization": true,
        "publicNetworkAccess": "[if(variables('isPrivateEndpointMode'), 'Disabled', 'Enabled')]",
        "networkAcls": {
          "bypass": "AzureServices",
          "defaultAction": "[if(variables('isPublicAccessMode'), 'Allow', 'Deny')]",
          "virtualNetworkRules": "[if(variables('isServiceEndpointMode'), createArray(createObject('id', reference(resourceId('Microsoft.Network/virtualNetworks', variables('vnetName')), '2024-05-01').subnets[0].id)), createArray())]",
          "ipRules": []
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/virtualNetworks', variables('vnetName'))]"
      ]
    },
    {
      "condition": "[and(parameters('createManagedKeyVault'), parameters('persistManagedKeyVault'), parameters('applyManagedKeyVaultLock'))]",
      "type": "Microsoft.KeyVault/vaults/providers/locks",
      "apiVersion": "2020-05-01",
      "name": "[format('{0}/Microsoft.Authorization/cert-runner-dnd-lock', parameters('keyVaultName'))]",
      "properties": {
        "level": "CanNotDelete",
        "notes": "Persisted by cert-runner deployment for future renewals."
      },
      "dependsOn": [
        "[resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName'))]"
      ]
    },
    {
      "condition": "[and(variables('isPrivateEndpointMode'), parameters('createPrivateDnsZone'), variables('canManagePrivateDnsInCurrentRg'))]",
      "type": "Microsoft.Network/privateDnsZones",
      "apiVersion": "2024-06-01",
      "name": "[parameters('keyVaultPrivateDnsZoneName')]",
      "location": "global",
      "tags": {
        "deployedBy": "cert-runner-template",
        "cleanupPolicy": "EOD"
      }
    },
    {
      "condition": "[and(variables('isPrivateEndpointMode'), variables('canManagePrivateDnsInCurrentRg'))]",
      "type": "Microsoft.Network/privateDnsZones/virtualNetworkLinks",
      "apiVersion": "2024-06-01",
      "name": "[format('{0}/{1}', parameters('keyVaultPrivateDnsZoneName'), variables('privateDnsZoneLinkName'))]",
      "location": "global",
      "properties": {
        "registrationEnabled": false,
        "virtualNetwork": {
          "id": "[resourceId('Microsoft.Network/virtualNetworks', variables('vnetName'))]"
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/virtualNetworks', variables('vnetName'))]"
      ]
    },
    {
      "condition": "[variables('isPrivateEndpointMode')]",
      "type": "Microsoft.Network/privateEndpoints",
      "apiVersion": "2024-05-01",
      "name": "[variables('privateEndpointName')]",
      "location": "[parameters('location')]",
      "properties": {
        "subnet": {
          "id": "[reference(resourceId('Microsoft.Network/virtualNetworks', variables('vnetName')), '2024-05-01').subnets[0].id]"
        },
        "privateLinkServiceConnections": [
          {
            "name": "kv-connection",
            "properties": {
              "privateLinkServiceId": "[variables('effectiveKeyVaultId')]",
              "groupIds": [
                "vault"
              ]
            }
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/virtualNetworks', variables('vnetName'))]"
      ]
    },
    {
      "condition": "[variables('isPrivateEndpointMode')]",
      "type": "Microsoft.Network/privateEndpoints/privateDnsZoneGroups",
      "apiVersion": "2024-05-01",
      "name": "[format('{0}/default', variables('privateEndpointName'))]",
      "properties": {
        "privateDnsZoneConfigs": [
          {
            "name": "vault-dns",
            "properties": {
              "privateDnsZoneId": "[variables('privateDnsZoneId')]"
            }
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/privateEndpoints', variables('privateEndpointName'))]"
      ]
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[resourceId(parameters('dnsZoneResourceGroup'), 'Microsoft.Network/dnsZones', parameters('dnsZoneName'))]",
      "name": "[guid(resourceId(parameters('dnsZoneResourceGroup'), 'Microsoft.Network/dnsZones', parameters('dnsZoneName')), resourceId('Microsoft.Compute/virtualMachines', variables('vmName')), 'dns-zone-contributor')]",
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', 'befefa01-2a29-4197-83a8-272ff33ce314')]",
        "principalId": "[reference(resourceId('Microsoft.Compute/virtualMachines', variables('vmName')), '2024-03-01', 'full').identity.principalId]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Compute/virtualMachines', variables('vmName'))]"
      ]
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[variables('effectiveKeyVaultId')]",
      "name": "[guid(variables('effectiveKeyVaultId'), resourceId('Microsoft.Compute/virtualMachines', variables('vmName')), 'keyvault-certificates-officer')]",
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', 'a4417e6f-fecd-4de8-b567-7b0420556985')]",
        "principalId": "[reference(resourceId('Microsoft.Compute/virtualMachines', variables('vmName')), '2024-03-01', 'full').identity.principalId]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Compute/virtualMachines', variables('vmName'))]"
      ]
    }
  ],
  "outputs": {
    "runnerVmName": {
      "type": "string",
      "value": "[variables('vmName')]"
    },
    "runnerPublicIp": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Network/publicIPAddresses', variables('pipName')), '2024-05-01').ipAddress]"
    },
    "dnsZoneId": {
      "type": "string",
      "value": "[resourceId(parameters('dnsZoneResourceGroup'), 'Microsoft.Network/dnsZones', parameters('dnsZoneName'))]"
    },
    "keyVaultId": {
      "type": "string",
      "value": "[variables('effectiveKeyVaultId')]"
    },
    "keyVaultAccessModeUsed": {
      "type": "string",
      "value": "[parameters('keyVaultAccessMode')]"
    },
    "managedKeyVaultCreated": {
      "type": "bool",
      "value": "[parameters('createManagedKeyVault')]"
    },
    "privateEndpointCreated": {
      "type": "bool",
      "value": "[variables('isPrivateEndpointMode')]"
    },
    "certDomains": {
      "type": "array",
      "value": "[union(createArray(parameters('primaryDomain')), parameters('additionalDomains'))]"
    },
    "keyVaultCertificateNameOut": {
      "type": "string",
      "value": "[parameters('keyVaultCertificateName')]"
    },
    "letsEncryptEmailOut": {
      "type": "string",
      "value": "[parameters('letsEncryptEmail')]"
    },
    "note": {
      "type": "string",
      "value": "[if(parameters('deleteVmOnSuccess'), 'Example deployed. Configure certmgr script execution and delete VM after success.', 'Example deployed. VM retained for debugging.')]"
    }
  }
}